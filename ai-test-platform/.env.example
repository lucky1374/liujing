# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=ai_test_platform

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Python Runner配置
# 可选：指定自定义Python解释器路径；默认优先使用 python-runner/.venv/bin/python
PYTHON_BIN=

# Seed初始化账号配置
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_REAL_NAME=平台管理员

# AI配置
# 可选值: openai, qianwen, ernie
AI_PROVIDER=qianwen
AI_API_KEY=your-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-turbo

# 前端地址
FRONTEND_URL=http://localhost:5173
